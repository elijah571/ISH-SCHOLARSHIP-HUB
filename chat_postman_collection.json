{
  "info": {
    "name": "Customer Service Chat API",
    "_postman_id": "f3b9f7a0-1234-5678-90ab-cdef12345678",
    "description": "Postman collection for production-ready customer service chat backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create or Get Chat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat"]
        }
      }
    },
    {
      "name": "Get My Chats",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat"]
        }
      }
    },
    {
      "name": "Get Chat Messages",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat/{{CHAT_ID}}/messages",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat", "{{CHAT_ID}}", "messages"]
        }
      }
    },
    {
      "name": "Send Text Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hello, how can I help you?\",\n  \"messageType\": \"text\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat/{{CHAT_ID}}/message",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat", "{{CHAT_ID}}", "message"]
        }
      }
    },
    {
      "name": "Upload Image/File",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat/{{CHAT_ID}}/upload",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat", "{{CHAT_ID}}", "upload"]
        }
      }
    },
    {
      "name": "Get All Chats (Admin)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/chat/admin/all",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "chat", "admin", "all"]
        }
      }
    }
  ],
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000" },
    { "key": "TOKEN", "value": "" },
    { "key": "CHAT_ID", "value": "" }
  ]
}