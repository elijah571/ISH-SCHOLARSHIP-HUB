# ─── Server ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Sequelize / PostgreSQL) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<password>
DB_NAME=ISH-SCHOOLARSHIP

# ─── JWT ──────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET=<64-byte-hex-string>
JWT_REFRESH_SECRET=<64-byte-hex-string>
JWT_EMAIL_VERIFY_SECRET=<64-byte-hex-string>
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Email (SMTP) ─────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=<mailtrap-user>
SMTP_PASS=<mailtrap-pass>
EMAIL_FROM=no-reply@yourdomain.com

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_NAME=<cloud-name>
CLOUDINARY_API=<api-key>
CLOUDINARY_SECRET=<api-secret>

# ─── CORS / URLs ──────────────────────────────────
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
