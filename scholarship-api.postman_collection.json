{
  "info": {
    "name": "Scholarship API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Test Scholarship CRUD, Search, Filter & Pagination"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000" },
    { "key": "TOKEN", "value": "" },
    { "key": "CSRF_TOKEN", "value": "" },
    { "key": "SCHOLARSHIP_ID", "value": "" }
  ],
  "item": [
    {
      "name": "Get CSRF Token",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/csrf"
      }
    },
    {
      "name": "Create Scholarship (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
          { "key": "X-CSRF-Token", "value": "{{CSRF_TOKEN}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Canada Fully Funded Scholarship",
              "type": "text"
            },
            {
              "key": "description",
              "value": "This scholarship covers tuition, accommodation, travel allowance and monthly stipend.",
              "type": "text"
            },
            { "key": "country", "value": "Canada", "type": "text" },
            { "key": "deadline", "value": "2026-06-30", "type": "text" },
            { "key": "funding_type", "value": "Fully Funded", "type": "text" },
            { "key": "image", "type": "file" }
          ]
        },
        "url": "{{BASE_URL}}/api/scholarship/create"
      }
    },
    {
      "name": "Get All Scholarships",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/scholarship"
      }
    },
    {
      "name": "Search Scholarships",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/scholarship?search=canada"
      }
    },
    {
      "name": "Filter Scholarships",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/scholarship?country=Canada&funding_type=Fully Funded"
      }
    },
    {
      "name": "Paginated Scholarships",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/scholarship?page=1&limit=5"
      }
    },
    {
      "name": "Get Scholarship By ID",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/scholarship/{{SCHOLARSHIP_ID}}"
      }
    },
    {
      "name": "Update Scholarship",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
          { "key": "X-CSRF-Token", "value": "{{CSRF_TOKEN}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Updated Scholarship Title",
              "type": "text"
            },
            { "key": "image", "type": "file" }
          ]
        },
        "url": "{{BASE_URL}}/api/scholarship/{{SCHOLARSHIP_ID}}"
      }
    },
    {
      "name": "Delete Scholarship",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
          { "key": "X-CSRF-Token", "value": "{{CSRF_TOKEN}}" }
        ],
        "url": "{{BASE_URL}}/api/scholarship/{{SCHOLARSHIP_ID}}"
      }
    }
  ]
}
